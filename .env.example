# ─────────────────────────────────────────────────────────────
# tg-poster-saas — приклад змінних оточення.
# Скопіюй у .env та заповни. .env у .gitignore — НЕ комітити секрети.
# ─────────────────────────────────────────────────────────────

# Neon Postgres (serverless). Бери pooled connection string з Neon.
DATABASE_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/tgposter?sslmode=require"

# Хост застосунку (без протоколу). Локально localhost:3000, на проді — netlify-домен.
APP_HOST="localhost:3000"
APP_ALLOWED_HOSTS="localhost:3000,127.0.0.1:3000"

# Майстер-ключ шифрування at-rest (AES-256-GCM). 32 байти у hex (64 символи).
# Згенерувати: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=""

# Секрет сесій веб-адміна.
AUTH_SECRET=""

# ── Telegram бот (BotFather) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=""
# Випадковий рядок: ставиться у setWebhook як secret_token і перевіряється на /api/bot.
TELEGRAM_WEBHOOK_SECRET=""

# ── Telegram MTProto (для скрейпу історії каналу під стиль) ────
# my.telegram.org → API development tools.
TELEGRAM_API_ID=""
TELEGRAM_API_HASH=""

# ── Глобальні AI-ключі (фолбек). Per-tenant ключі — у БД (шифровані). ─
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Захист крон-роуту /api/cron/daily.
CRON_SECRET=""

# ── Початковий власник (сід веб-адміна) ───────────────────────
SEED_ADMIN_LOGIN="admin"
SEED_ADMIN_PASSWORD="change-me-12345"
# Твій Telegram user id (числом) — прив'язка до першого tenant.
OWNER_TG_ID=""
