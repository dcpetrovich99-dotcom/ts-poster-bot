// tg-poster-saas — SaaS-бот автопостингу в Telegram-канали.
// PostgreSQL (Neon). Multi-tenant: усе ізольовано по tenantId.
// Фаза 1 працює під одного власника, але схема одразу багатотенантна.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Tenant (workspace) ─────────────────────────────────────────────
// Один tenant = один ізольований акаунт зі своїми каналами, ключами,
// постами й балансом. Прив'язується до сесії активації (вимога SaaS).

model Tenant {
  id        String       @id @default(cuid())
  name      String
  ownerTgId String? // Telegram user id власника (числом, як рядок)
  status    TenantStatus @default(active)

  // «Сесія активації»: токен + метадані пристрою/IP, з якого активували бота.
  // Активація з нової сесії → новий tenant зі своїми каналами.
  activationToken String?  @unique
  activationIp    String?
  activationUa    String?

  // CTA-кнопка «написать нам» — опційна, керується з бота (/settings).
  ctaEnabled Boolean @default(false)
  // Тимчасовий режим бота для багатокрокових дій без сесій ("learn" тощо).
  pendingMode   String?
  pendingModeAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminUsers   AdminUser[]
  credentials  ApiCredential[]
  channels     TgChannel[]
  userSessions TgUserSession[]
  styleProfile StyleProfile?
  posts        Post[]
  planItems    ContentPlanItem[]
  linkSettings LinkSetting[]
  ledger       BalanceEntry[]

  @@index([ownerTgId])
}

enum TenantStatus {
  active
  suspended
}

// ── Веб-адмін: автентифікація (патерн з agency-site/src/lib/auth.ts) ─

enum AdminRole {
  superadmin // глобальний власник сервісу — бачить усі tenants/канали в адмінці
  owner // власник свого tenant
  editor
}

model AdminUser {
  id           String    @id @default(cuid())
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId     String
  login        String    @unique
  passwordHash String
  role         AdminRole @default(editor)
  createdAt    DateTime  @default(now())
  sessions     Session[]

  @@index([tenantId])
}

model Session {
  id          String    @id @default(cuid())
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  adminUserId String
  tokenHash   String    @unique // SHA-256 від випадкового токена з cookie
  userAgent   String?
  ip          String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime

  @@index([adminUserId])
  @@index([expiresAt])
}

// ── AI-ключі та баланс (per-tenant) ────────────────────────────────

enum AiProvider {
  openai
  anthropic
}

model ApiCredential {
  id           String     @id @default(cuid())
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId     String
  provider     AiProvider
  // Ключ шифрується AES-256-GCM (lib/crypto.ts) — у БД лише шифротекст.
  keyEncrypted String
  label        String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
}

// Облік балансу/поповнень (кредити в умовних одиницях або копійках).
model BalanceEntry {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  amount    Int // + поповнення, − списання
  reason    String // "topup" | "post_generation" | "image" тощо
  meta      String? // JSON-рядок із деталями
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

// ── Telegram-канали ────────────────────────────────────────────────

model TgChannel {
  id          String   @id @default(cuid())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  chatId      String // числовий id каналу (рядком, з −100…)
  username    String? // @username без @ (за наявності)
  title       String?
  // Знімок прав бота (getChatMember): чи може постити/закріплювати.
  canPost     Boolean  @default(false)
  canPin      Boolean  @default(false)
  isDefault   Boolean  @default(false) // канал за замовчуванням для постингу
  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts Post[]

  @@unique([tenantId, chatId])
  @@index([tenantId])
}

// MTProto user-сесія власника (GramJS) — для скрейпу історії під стиль.
// session string шифрується AES-256-GCM.
model TgUserSession {
  id               String   @id @default(cuid())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId         String
  sessionEncrypted String
  phone            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId])
}

// ── Профіль стилю каналу ───────────────────────────────────────────

enum StyleSource {
  scrape // авто-аналіз історії каналу (MTProto)
  manual // ручні референси з адмінки
  hybrid
}

model StyleProfile {
  id       String      @id @default(cuid())
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String      @unique
  source   StyleSource @default(manual)

  // Структурований аналіз (JSON-рядок): тон, емодзі, довжина, CTA, рубрики.
  analysisJson String?
  // Візуальна айдентика (JSON): палітра hex, стиль, композиція, mood (Claude Vision).
  brandKitJson String?
  // Тематика/ніша каналу (вільний текст від власника).
  topic        String?
  // Сирі референс-пости (для порожнього каналу або як приклади few-shot).
  referencesJson String?
  // URL/Blob-ключі референс-картинок.
  refImagesJson  String?

  samplesCount Int      @default(0)
  updatedAt    DateTime @updatedAt
}

// ── Пости ──────────────────────────────────────────────────────────

enum PostType {
  news // новость
  case // кейс
  review // отзыв
  about // про нас / інфа
  update // апдейт (нове джерело)
  blog // блог / власний досвід
  fun // цікава штука
  info // просто інфа
}

enum PostStatus {
  draft
  awaiting_approval
  scheduled
  published
  failed
}

enum MediaType {
  none
  image
  video
}

enum GeneratedBy {
  gpt
  claude
  manual
}

model Post {
  id        String    @id @default(cuid())
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  channel   TgChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  channelId String?

  type   PostType
  status PostStatus @default(draft)

  topic       String? // тема, з якої згенеровано
  bodyHtml    String     @default("") // готовий Telegram-HTML текст
  hashtagsJson String?   // JSON-масив хештегів
  // Інлайн-кнопки (JSON-масив {label,url}) — зокрема синя CTA-кнопка.
  buttonsJson String?

  mediaType MediaType @default(none)
  mediaRef  String? // Netlify Blob-ключ (генерація/аплоад) або tg file_id
  mediaMime String?

  pinOnPublish Boolean     @default(true)
  generatedBy  GeneratedBy @default(gpt)

  scheduledAt DateTime?
  publishedAt DateTime?
  tgMessageId Int? // message_id у каналі після публікації

  errorText String? // діагностика при status=failed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([scheduledAt])
}

// ── Контент-план (живить щоденні нагадування) ──────────────────────

enum PlanItemStatus {
  suggested
  accepted
  skipped
  done
}

model ContentPlanItem {
  id       String         @id @default(cuid())
  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String
  date     DateTime // запланована дата
  topic    String
  type     PostType
  notes    String?
  status   PlanItemStatus @default(suggested)
  createdAt DateTime      @default(now())

  @@index([tenantId, date])
  @@index([tenantId, status])
}

// ── Редаговані посилання (CTA «написать нам», менеджер тощо) ────────

// Медіа (згенеровані/завантажені картинки та відео) — у БД (персистентно на
// будь-якому хості, без ефемерного диска / зовнішнього сховища).
model MediaBlob {
  id        String   @id @default(cuid())
  mime      String
  data      Bytes
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model LinkSetting {
  id       String   @id @default(cuid())
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String
  key      String // напр. "contact_us" (CTA), "manager", "channel"
  label    String // текст кнопки/посилання ("Написать нам")
  url      String // приватне посилання (t.me/...)
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
}
